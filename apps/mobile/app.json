{
  "expo": {
    "name": "Goldngoose",
    "slug": "goldngoose-terminal",
    "version": "0.1.0",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.goldngoose.terminal"
    },
    "android": {
      "package": "com.goldngoose.terminal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "goldngoose",
    "platforms": ["ios", "android", "web"]
  }
}
